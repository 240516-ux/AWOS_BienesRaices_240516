extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-orange-400 Bienes
            span.font-normal.text-black Raíces

        h2.text-center.text-2xl.font-normal.text-black Por favor ingresa cuidadosamente tus datos

        .mt-8.mx-auto.max-w-xl
            .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
                form.space-y-5
                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
                        input#emailUsuario(type="email" name="emailUsuario" placeholder="p.e.: correo@dominio.com" class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300 focus:outline-none")

                    input(type="submit" value="Enviar Correo de Restauración" class="w-full bg-gray-300 text-orange-400 hover:bg-orange-400 hover:text-white font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase transition-all duration-200")

                    div.flex.items-center.justify-between.pt-3
                        a(href="/auth/login" class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2") ¿Ya tienes cuenta? Inicia Sesión
                        a(href="/auth/registro" class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2") ¿No tienes cuenta? Regístrate