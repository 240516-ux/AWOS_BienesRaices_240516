extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.text-center.text-orange-400 Resetear Contraseña

        if errores
            each error in errores
                p.text-red-500= error.msg

                       .mt-8.mx-auto.max-w-xl
                          .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
                              form(method="POST" action="/auth/actualizarPassword")
                    
                              input(type="hidden" name="emailSolicitante" value=email)

                              input(type="password" name="passwordUsuario" placeholder="Nueva contraseña" class="w-full mb-3")

                              input(type="password" name="confirmacionUsuario" placeholder="Confirmar contraseña" class="w-full mb-3")

                              input(type="submit" value="Actualizar contraseña" class="w-full bg-orange-400 text-white py-2 rounded")