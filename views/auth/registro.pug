extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-orange-400 Bienes
            span.font-normal.text-black Raíces
            
            h2.text-center.text-2xl.font-normal.text-black Por favor ingresa cuidadosamente tus datos
            if errores
            each error in errores
             p.bg-red-500.text-white.text-center.my-2.p-2= error.msg
             
              .mt-8.mx-auto.max-w-xl
              .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
              form.space-y-5(method="POST" action="/auth/registro" noValidate)

                    input(type="hidden" name="_csrf" value=csrfToken)

                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="nombreUsuario") Nombre completo:
                        input#nombreUsuario(
                            type="text"
                            name="nombreUsuario"
                            placeholder="p.e.: Alan Cruz Baltazar"
                            class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300 focus:outline-none"
                        )
                        
                        div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
                        input#emailUsuario(
                            type="email"
                            name="emailUsuario"
                            placeholder="p.e.: alan@email.com"
                            class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300 focus:outline-none"
                        )
                        
                        div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Contraseña:
                        input#passwordUsuario(
                            type="password"
                            name="passwordUsuario"
                            placeholder="Por lo menos 8 caracteres"
                            class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 hover:inset-shadow-sm focus:inset-shadow-md focus:inset-shadow-orange-300/50 focus:outline-none"
                        )
                        
                         div.px-5
                         label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmacionUsuario") Confirmación de contraseña:
                         input#confirmacionUsuario(
                            type="password"
                            name="confirmacionUsuario"
                            placeholder="Repite la contraseña anterior"
                            class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 hover:inset-shadow-sm focus:inset-shadow-md focus:inset-shadow-orange-300/50 focus:outline-none"
                        )
                        
                        input(
                        type="submit"
                        value="Registrar Usuario"
                        class="w-full bg-gray-300 text-orange-400 hover:bg-orange-400 hover:text-white font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase transition-all duration-200"
                    )

                    div.flex.items-center.justify-between.pt-3
                        a(
                            href="/auth/login"
                            class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2"
                        ) ¿Ya tienes cuenta? Inicia Sesión

                        a(
                            href="/auth/recuperarPassword"
                            class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2"
                        ) ¿Olvidaste tu contraseña? Recupérala